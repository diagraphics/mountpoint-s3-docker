#!/command/execlineb -P
# shellcheck disable=all

with-s3-env
getcwd -E cwd
s6-envdir "${cwd}/env"
multisubstitute {
    importas -i bucket MOUNTPOINT_BUCKET
    importas -i mount_dir MOUNTPOINT_DIR
    importas -s args MOUNTPOINT_ARGS
    importas -D /var/cache/mount-s3 cache_dir MOUNTPOINT_CACHE_DIR
}
s6-notifyoncheck -n 0 -c "mountpoint -q ${mount_dir}"
mount-s3 \
    --foreground \
    --force-path-style \
    --upload-checksums off \
    --cache "${cache_dir}/${bucket}" \
    $args $bucket $mount_dir
