#!/command/execlineb -s0
# shellcheck disable=all

with-contenv
importas -D 1 -u proxy MOUNTPOINT_USE_PROXY
importas -i -u url AWS_ENDPOINT_URL
with-url-parts -p AWS_UPSTREAM_ $url
backtick -E endpoint          # Redefine AWS_ENDPOINT_URL
{
    ifelse
    {
        eltest $proxy = 1
    }
    {                                # to point to local proxy
        trurl $url \
            --set scheme=http \
            --set host=localhost \
            --set port=54321
    }
    echo $url
}
print { "Resolved Endpoint: ${endpoint}" }
print { "Using Proxy: ${proxy}" }
export AWS_ENDPOINT_URL $endpoint
# export AWS_EC2_METADATA_DISABLED 1  # Disable EC2 metadata service
# export AWS_SHARED_CREDENTIALS_FILE "/dev/null"
# export AWS_CONFIG_FILE "/dev/null"
emptyenv -c                         # Clear substituted variables
$@
